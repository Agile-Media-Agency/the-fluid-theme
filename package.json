{
  "name": "the-fluid-theme",
  "version": "0.3.3",
  "description": "A modern, semantic CSS design system built on physics principles — not utility classes",
  "main": "src/fluid.css",
  "style": "src/fluid.css",
  "files": [
    "src/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "serve": "npx http-server . -o /index.html",
    "test": "echo \"Visual testing only - open examples/foundation.html in browser\""
  },
  "keywords": [
    "css",
    "design-system",
    "theme",
    "framework",
    "semantic",
    "css-layers",
    "custom-properties",
    "logical-properties",
    "oklch",
    "no-build"
  ],
  "author": "Neil White",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agile-Media-Agency/the-fluid-theme.git"
  },
  "bugs": {
    "url": "https://github.com/Agile-Media-Agency/the-fluid-theme/issues"
  },
  "homepage": "https://thefluidtheme.com",
  "engines": {
    "browsers": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions"
    ]
  },
  "browserslist": [
    "supports css-cascade-layers",
    "supports css-container-queries",
    "supports css-logical-properties"
  ]
}
