{
  "name": "@fluid-theme/core",
  "version": "0.4.2",
  "description": "A modern, semantic CSS design system built on physics principles — not utility classes",
  "main": "dist/fluid.min.css",
  "style": "dist/fluid.min.css",
  "exports": {
    ".": "./dist/fluid.min.css",
    "./src": "./src/fluid.css"
  },
  "files": [
    "dist/",
    "src/",
    "fluid-agent-kit/",
    "CLAUDE.md",
    "AGENTS.md",
    "GEMINI.md",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "serve": "npx http-server . -o /index.html",
    "build": "node scripts/build-css.mjs",
    "prepublishOnly": "npm run build",
    "optimize-images": "node scripts/optimize-images.js",
    "test": "echo \"Visual testing only - open examples/foundation.html in browser\""
  },
  "keywords": [
    "css",
    "design-system",
    "theme",
    "framework",
    "semantic",
    "css-layers",
    "custom-properties",
    "logical-properties",
    "oklch",
    "no-build"
  ],
  "author": "Neil White",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agile-Media-Agency/the-fluid-theme.git"
  },
  "bugs": {
    "url": "https://github.com/Agile-Media-Agency/the-fluid-theme/issues"
  },
  "homepage": "https://thefluidtheme.com",
  "engines": {
    "browsers": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions"
    ]
  },
  "browserslist": [
    "supports css-cascade-layers",
    "supports css-container-queries",
    "supports css-logical-properties"
  ],
  "devDependencies": {
    "lightningcss": "^1.32.0",
    "sharp": "^0.34.5"
  }
}
